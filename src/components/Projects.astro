---
// Projects.astro
---

<section id="projects" class="projects-section section">
        <div class="container">
            <h2 class="section-title reveal">Featured <span class="text-gradient">&nbsp;Projects</span></h2>
            <div class="projects-list reveal">


                <!-- Project 2 -->
                <div class="project-item glass-card">
                    <div class="project-header">
                        <div class="project-title-area">
                            <i class="fas fa-phone-alt project-icon"></i>
                            <h3 class="project-title">Caller-ID Masking System</h3>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div class="project-details">
                        <p class="project-desc">Built a secure call-center solution on Issabel with extensive
                            customizations in Asterisk dialplan. Implemented alias-based calling with full caller-ID
                            masking, using MySQL (ODBC) for dynamic number mapping. Engineered advanced call handling
                            with custom context routing, CDR manipulation, and MixMonitor control for recording and
                            auditing.</p>
                        <div class="project-tech">
                            <span>Call Center</span><span>Asterisk</span><span>MySQL</span>
                        </div>
                        <div class="project-links">
                            <a href="project-caller-id.html" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;">View Details <i class="fas fa-arrow-right" style="margin-left: 0.5rem; font-size: 0.8rem;"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Project 3 -->
                <div class="project-item glass-card">
                    <div class="project-header">
                        <div class="project-title-area">
                            <i class="fas fa-shield-alt project-icon"></i>
                            <h3 class="project-title">IPTables Monitoring & Alerting System</h3>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div class="project-details">
                        <p class="project-desc">Implemented an automated firewall monitoring solution using iptables
                            across multiple PBX servers, with real-time alerts to detect suspicious traffic and
                            unauthorized access attempts.</p>
                        <div class="project-tech">
                            <span>Security</span><span>Linux</span><span>Bash</span>
                        </div>
                        <div class="project-links">
                            <a href="project-iptables.html" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;">View Details <i class="fas fa-arrow-right" style="margin-left: 0.5rem; font-size: 0.8rem;"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Project 4 -->
                <div class="project-item glass-card">
                    <div class="project-header">
                        <div class="project-title-area">
                            <i class="fas fa-hdd project-icon"></i>
                            <h3 class="project-title">Proxmox Backup Server Deployment</h3>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div class="project-details">
                        <p class="project-desc">Deployed and configured Proxmox Backup Server for centralized,
                            efficient, and secure backups of virtual machines, improving disaster recovery and data
                            reliability.</p>
                        <div class="project-tech">
                            <span>Proxmox</span><span>Backup</span><span>SysAdmin</span>
                        </div>
                        <div class="project-links">
                            <a href="project-proxmox-backup.html" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;">View Details <i class="fas fa-arrow-right" style="margin-left: 0.5rem; font-size: 0.8rem;"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Project 5 -->
                <div class="project-item glass-card">
                    <div class="project-header">
                        <div class="project-title-area">
                            <i class="fas fa-expand-arrows-alt project-icon"></i>
                            <h3 class="project-title">Proxmox VM Auto Disk Expansion</h3>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div class="project-details">
                        <p class="project-desc">Developed a lightweight automation for Proxmox VE that automatically
                            extends VM disk space when thresholds are reached, reducing manual intervention and downtime
                            risk.</p>
                        <div class="project-tech">
                            <span>Proxmox</span><span>Automation</span><span>Storage</span>
                        </div>
                        <div class="project-links">
                            <a href="project-proxmox-expansion.html" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;">View Details <i class="fas fa-arrow-right" style="margin-left: 0.5rem; font-size: 0.8rem;"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Project 6 -->
                <div class="project-item glass-card">
                    <div class="project-header">
                        <div class="project-title-area">
                            <i class="fas fa-chart-line project-icon"></i>
                            <h3 class="project-title">Monitoring Stack using Prometheus & Grafana</h3>
                        </div>
                        <i class="fas fa-chevron-down toggle-icon"></i>
                    </div>
                    <div class="project-details">
                        <p class="project-desc">Built a containerized monitoring system using Prometheus, Grafana, and
                            Docker with node exporters for PBX and mail servers, enabling real-time metrics, dashboards,
                            and alerting.</p>
                        <div class="project-tech">
                            <span>Prometheus</span><span>Grafana</span><span>Docker</span>
                        </div>
                        <div class="project-links">
                            <a href="project-monitoring-stack.html" class="btn btn-outline" style="padding: 0.4rem 1rem; font-size: 0.9rem;">View Details <i class="fas fa-arrow-right" style="margin-left: 0.5rem; font-size: 0.8rem;"></i></a>
                        </div>
                    </div>
                </div>



            </div>
        </div>
    </section>